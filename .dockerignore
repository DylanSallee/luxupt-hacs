# =============================================================================
# LuxUPT Docker Ignore
# =============================================================================
# Optimized for minimal image size and build cache efficiency.
# The Dockerfile copies files in this order for best caching:
#   1. pyproject.toml, poetry.lock (dependency layer - rarely changes)
#   2. src/, README.md (source layer - changes frequently)
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python build artifacts and caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
.hypothesis/

# Type checking and linting caches
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.env
.env.*
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Node.js / Frontend build tools
# CSS is pre-compiled; npm only needed for development
# -----------------------------------------------------------------------------
node_modules/
package.json
package-lock.json
eslint.config.js
tailwind.config.js

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Docker and Compose (meta files, not needed in image)
# -----------------------------------------------------------------------------
Dockerfile
.dockerignore
docker-compose*.yml
compose*.yaml

# -----------------------------------------------------------------------------
# Build and development scripts
# -----------------------------------------------------------------------------
Makefile
build.sh
gather_reqs.sh
set_env*.sh

# -----------------------------------------------------------------------------
# Documentation (README.md explicitly copied in Dockerfile)
# -----------------------------------------------------------------------------
*.md
!README.md
docs/

# -----------------------------------------------------------------------------
# Output directories (mounted as volumes at runtime)
# -----------------------------------------------------------------------------
output/

# -----------------------------------------------------------------------------
# Temporary and log files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.cache/

# -----------------------------------------------------------------------------
# CI/CD configuration
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml

# -----------------------------------------------------------------------------
# Development and tool configuration
# -----------------------------------------------------------------------------
.pre-commit-config.yaml
.pylintrc
.flake8
tox.ini
.claude/
concat_*/

# -----------------------------------------------------------------------------
# Test files (not needed in production image)
# -----------------------------------------------------------------------------
tests/
test_*.py
*_test.py

# -----------------------------------------------------------------------------
# External service configs (nginx runs as separate container)
# -----------------------------------------------------------------------------
nginx/
